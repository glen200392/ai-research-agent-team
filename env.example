# ═══════════════════════════════════════════════════════
#  AI Investment Pipeline — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── LLM API Keys ────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Stage 0.5: FRED Macro Data (FREE, required) ───────────────
# Get your free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# Used for: T10Y2Y yield curve, FEDFUNDS rate direction
FRED_API_KEY=your_fred_api_key_here

# ── Email Delivery ───────────────────────────────────────
REPORT_EMAIL=your@email.com

# ── Pipeline Schedule (Asia/Taipei) ─────────────────────────
# Taiwan Pipeline:  07:00 TST daily  (cron: 0 7 * * *)
# US Pipeline:      22:00 TST daily  (cron: 0 22 * * *)
# Japan Pipeline:   22:00 TST daily  (cron: 0 22 * * *)

# ── Optional: Nebula Platform ─────────────────────────────
NEBULA_API_KEY=

# ── Optional: LangFuse Observability ────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Optional: Redis Checkpoint ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ════════════════════════════════════════════════════════════════
#  INVESTMENT DISCLAIMER
# ════════════════════════════════════════════════════════════════
